    "/Bff/login": {
      "get": {
        "tags": [
          "Bff"
        ],
        "summary": "Initiates the OIDC Authorization Code + PKCE flow by redirecting to the Identity Provider.\r\nThe Angular app should navigate to this URL (not call it via AJAX).",
        "operationId": "login",
        "parameters": [
          {
            "name": "returnUrl",
            "in": "query",
            "description": "Path to redirect back to after successful login. Defaults to \"/\".",
            "schema": {
              "type": "string",
              "default": "/"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Bff/user": {
      "get": {
        "tags": [
          "Bff"
        ],
        "summary": "Returns the current user's claims as JSON.\r\nThe Angular app calls this to check if a session is active and to retrieve user info.\r\nReturns 401 if the user is not authenticated.",
        "operationId": "getUser",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Bff/logout": {
      "post": {
        "tags": [
          "Bff"
        ],
        "summary": "Signs out of the local cookie session and the OIDC Identity Provider.",
        "operationId": "logout",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
