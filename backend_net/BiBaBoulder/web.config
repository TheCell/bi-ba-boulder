<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Remove WebDAV module globally so PUT/DELETE verbs are not blocked -->
  <system.webServer>
    <modules>
      <remove name="WebDAVModule" />
    </modules>
  </system.webServer>

  <!-- Main application configuration -->
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <remove name="WebDAV" />
        <remove name="OPTIONSVerbHandler" />
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" 
                  arguments=".\Thecell.Bibaboulder.BiBaBoulder.dll" 
                  stdoutLogEnabled="true" 
                  stdoutLogFile=".\logs\stdout" 
                  hostingModel="outofprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
      
      <!-- Enable static file serving -->
      <staticContent>
        <!-- Remove existing MIME types first to avoid 500.19 duplicate errors -->
        <!-- 
        <remove fileExtension=".glb" />
        <remove fileExtension=".gltf" />
        <remove fileExtension=".bin" />
        
        <mimeMap fileExtension=".glb" mimeType="model/gltf-binary" />
        <mimeMap fileExtension=".gltf" mimeType="model/gltf+json" />
        <mimeMap fileExtension=".bin" mimeType="application/octet-stream" />
        -->
      </staticContent>
      
      <!-- Security settings -->
      <security>
        <requestFiltering>
          <!-- Increase max request size for file uploads (100MB) -->
          <requestLimits maxAllowedContentLength="104857600" />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>
</configuration>
