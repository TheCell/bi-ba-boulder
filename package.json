{
  "name": "bibaboulder",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development",
    "startsecure": "ng serve --ssl true --configuration development",
    "host": "ng serve --host 0.0.0.0 --configuration development",
    "build": "ng build --base-href /bi-ba-boulder/ --configuration production",
    "buildpipeline": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "pregenerate:api-net": "node -e \"require('fs').rmSync('src/app/api-net', {recursive:true,force:true})\"",
    "generate:api-net": "openapi-generator-cli generate -c openapi-generator-net.yaml -o src/app/api-net"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.10",
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/forms": "^21.2.10",
    "@angular/platform-browser": "^21.2.10",
    "@angular/platform-browser-dynamic": "^21.2.10",
    "@angular/router": "^21.2.10",
    "@lume/three-meshline": "^4.0.5",
    "@openapitools/openapi-generator-cli": "^2.25.1",
    "@types/three": "^0.184.0",
    "ng-keyboard-shortcuts": "^13.0.8",
    "rxjs": "~7.8.0",
    "stats.js": "^0.17.0",
    "three": "^0.184.0",
    "three-mesh-ui": "^6.5.4",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^21.2.8",
    "@eslint/js": "^10.0.0",
    "@types/jasmine": "~6.0.0",
    "@types/three": "^0.184.0",
    "angular-eslint": "21.3.1",
    "eslint": "^10.3.0",
    "jasmine-core": "~6.2.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.59.3"
  }
}