{
  "openapi": "3.1.1",
  "info": {
    "title": "BiBaBoulder API",
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://localhost:5088"
    }
  ],
  "paths": {
    "/Bff/login": {
      "get": {
        "tags": [
          "Bff"
        ],
        "summary": "Initiates the OIDC Authorization Code + PKCE flow by redirecting to the Identity Provider.\r\nThe Angular app should navigate to this URL (not call it via AJAX).",
        "operationId": "login",
        "parameters": [
          {
            "name": "returnUrl",
            "in": "query",
            "description": "Path to redirect back to after successful login. Defaults to \"/\".",
            "schema": {
              "type": "string",
              "default": "/"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Bff/user": {
      "get": {
        "tags": [
          "Bff"
        ],
        "summary": "Returns the current user's claims as JSON.\r\nThe Angular app calls this to check if a session is active and to retrieve user info.\r\nReturns 401 if the user is not authenticated.",
        "operationId": "getUser",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Bff/logout": {
      "post": {
        "tags": [
          "Bff"
        ],
        "summary": "Signs out of the local cookie session and the OIDC Identity Provider.",
        "operationId": "logout",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Sectors": {
      "get": {
        "tags": [
          "Sectors"
        ],
        "operationId": "getSectors",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SectorDto"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SectorDto"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SectorDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Sectors"
        ],
        "operationId": "createSector",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSectorCommand"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSectorCommand"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSectorCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/SectorDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SectorDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/SectorDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/Sectors/{id}": {
      "get": {
        "tags": [
          "Sectors"
        ],
        "operationId": "getSector",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/SectorDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SectorDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/SectorDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/Test": {
      "get": {
        "tags": [
          "Test"
        ],
        "operationId": "getTest",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/TestDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TestDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/TestDto"
                }
              }
            }
          }
        }
      }
    },
    "/WeatherForecast": {
      "get": {
        "tags": [
          "WeatherForecast"
        ],
        "operationId": "get",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateSectorCommand": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "SectorDto": {
        "required": [
          "id",
          "name"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "TestDto": {
        "required": [
          "id",
          "spraywallCount"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "spraywallCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int64"
          }
        }
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "temperatureF": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "summary": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Bff"
    },
    {
      "name": "Sectors"
    },
    {
      "name": "Test"
    },
    {
      "name": "WeatherForecast"
    }
  ]
}